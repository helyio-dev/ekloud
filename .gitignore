# =============================================================================
# EKLOUD — .gitignore
# Vite + React + TypeScript + Supabase + pnpm
# =============================================================================


# =============================================================================
# DEPENDENCIES
# =============================================================================
node_modules/
.pnp
.pnp.js
.yarn/install-state.gz


# =============================================================================
# BUILD OUTPUT
# =============================================================================
dist/
dist-ssr/
build/
out/


# =============================================================================
# ENVIRONMENT & SECRETS
# Never commit API keys, tokens or secrets
# =============================================================================
.env
.env.local
.env.development
.env.production
.env.staging
.env.*.local
*.secret
*.secrets
.dev.vars


# =============================================================================
# TYPESCRIPT
# =============================================================================
*.tsbuildinfo
tsconfig.tsbuildinfo


# =============================================================================
# VITE
# =============================================================================
vite.config.ts.timestamp-*
vite.config.js.timestamp-*


# =============================================================================
# SUPABASE
# =============================================================================
supabase/.temp/
supabase/.branches/
supabase/functions/.env


# =============================================================================
# AI / LLM CONTEXT FILES
# Local AI workspace files — not for version control
# =============================================================================
.gemini/
.cursor/
.aider*
.claude/


# =============================================================================
# LOGS
# =============================================================================
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*


# =============================================================================
# CACHE & TEMP
# =============================================================================
.cache/
.tmp/
.temp/
*.tmp
*.temp
.parcel-cache/
.eslintcache
.stylelintcache
.prettiercache


# =============================================================================
# COVERAGE & TESTING
# =============================================================================
coverage/
*.lcov
.nyc_output/
playwright-report/
test-results/


# =============================================================================
# OS ARTIFACTS
# =============================================================================
# macOS
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
.AppleDouble
.LSOverride

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
Desktop.ini
$RECYCLE.BIN/

# Linux
*~


# =============================================================================
# EDITOR & IDE
# =============================================================================
# VSCode (keep settings but ignore local-only files)
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
!.vscode/launch.json

# JetBrains (IntelliJ, WebStorm, etc.)
.idea/
*.iml
*.iws
*.ipr

# Vim / Neovim
*.swp
*.swo
*.swn
Session.vim
.netrwhist

# Emacs
*#
.#*


# =============================================================================
# OPTIONAL: LOCALLY RESOLVED PACKAGES
# =============================================================================
package-lock.json
yarn.lock

copy-env.js
worker/.wrangler/*